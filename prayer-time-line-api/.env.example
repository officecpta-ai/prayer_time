## prayer-time-line-api
## 注意：不要把真實機密提交到 git

# Server
PORT=8080
# 建議部署時設定（用來產生 web view 絕對網址）；未設定時會用 request host 推導
PUBLIC_BASE_URL=

# LINE
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Web view link signing
VIEW_LINK_SECRET=

# OpenAI（整本手冊 QA）
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_QA_MODEL=gpt-4.1-mini

# Vertex AI Vector Search（整本手冊檢索）
VERTEX_PROJECT_ID=
VERTEX_LOCATION=asia-northeast1
VERTEX_INDEX_ID=
VERTEX_INDEX_ENDPOINT_ID=
VERTEX_DEPLOYED_INDEX_ID=prayer_time_handbook
VERTEX_PUBLIC_ENDPOINT_DOMAIN=
FIRESTORE_CHUNKS_COLLECTION=prayer_time_chunks

# Ragic
RAGIC_BASE_URL=https://ap13.ragic.com/asiahope
RAGIC_BASIC_RAW=true
RAGIC_API_KEY=
# 訂閱表單連結（LINE 書單訊息會附上；並用 pfv[field_id] 自動帶入 line_user_id）
RAGIC_SUBSCRIBE_FORM_URL=https://ap13.ragic.com/asiahope/gpt/4?ragic-web-embed=true&webaction=form&ver=new&version=2

# Ragic field IDs (reading record gpt/7)；姓名 1011771、教會 1011772
RAGIC_READING_RECORD_FIELD_LINE_USER_ID=1011768
RAGIC_READING_RECORD_FIELD_LINE_DISPLAY_NAME=
RAGIC_READING_RECORD_FIELD_USER_EMAIL=1011761
RAGIC_READING_RECORD_FIELD_BOOK_ID=1011762
RAGIC_READING_RECORD_FIELD_BOOK_NAME=1011763
RAGIC_READING_RECORD_FIELD_READING_DAY=1011764
RAGIC_READING_RECORD_FIELD_READ_TIME=1011765
RAGIC_READING_RECORD_FIELD_USER_NAME=1011771
RAGIC_READING_RECORD_FIELD_CHURCH=1011772

# 訂閱表（gpt/4）姓名、教會欄位 ID（寫入閱讀紀錄時從訂閱表帶入）
# RAGIC_SUBSCRIPTION_FIELD_USER_NAME=1011599
# RAGIC_SUBSCRIPTION_FIELD_CHURCH=1011773

