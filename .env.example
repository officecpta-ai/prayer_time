# Ragic
RAGIC_BASE_URL=https://ap13.ragic.com/asiahope
RAGIC_API_KEY=
# 若 Ragic 要求 API Key 用 query 傳送，設為 true（例：?APIKey=xxx）
RAGIC_API_KEY_IN_QUERY=
# 若 HTTP Basic 用「Basic + 金鑰字面」不編碼，設為 true
RAGIC_BASIC_RAW=
RAGIC_SUBSCRIPTION_FORM_URL=https://ap13.ragic.com/asiahope/gpt/4?ragic-web-embed=true&webaction=form&ver=new&version=2

# 訂閱表（gpt/4 禱告手冊訂閱）欄位 ID。姓名用於問候，姓名與教會會寫入閱讀紀錄。
# RAGIC_SUBSCRIPTION_FIELD_USER_NAME=1011599
# RAGIC_SUBSCRIPTION_FIELD_USER_EMAIL=1011595
# RAGIC_SUBSCRIPTION_FIELD_BOOK_ID=1011596
# RAGIC_SUBSCRIPTION_FIELD_BOOK_NAME=1011603
# RAGIC_SUBSCRIPTION_FIELD_IS_ACTIVE=1011597
# RAGIC_SUBSCRIPTION_FIELD_CHURCH=1011773

# 閱讀紀錄表（gpt/7）欄位 ID，每次閱讀寫入一筆。姓名 1011771、教會 1011772。
RAGIC_READING_RECORD_FIELD_USER_EMAIL=1011761
RAGIC_READING_RECORD_FIELD_BOOK_ID=1011762
RAGIC_READING_RECORD_FIELD_BOOK_NAME=1011763
RAGIC_READING_RECORD_FIELD_READING_DAY=1011764
RAGIC_READING_RECORD_FIELD_READ_TIME=1011765
RAGIC_READING_RECORD_FIELD_USER_NAME=1011771
RAGIC_READING_RECORD_FIELD_CHURCH=1011772

# OAuth 代理（供 GPTs 與 API 同網域）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 若 GOOGLE_CLIENT_SECRET 留空，deploy.sh 會改從 GCP Secret「google-oauth-client-secret」掛載（需先在 Secret Manager 建立並授權）
PUBLIC_BASE_URL=https://prayer-time-api-43747267943.asia-northeast1.run.app

# 本地開發時可不設，Cloud Run 會設 PORT
PORT=8080
