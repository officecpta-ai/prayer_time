# Ragic
RAGIC_BASE_URL=https://ap13.ragic.com/asiahope
RAGIC_API_KEY=
# 同步除錯：node scripts/sync-ragic-to-qdrant.js 前設為 true 可印出回傳結構
# RAGIC_SYNC_DEBUG=true
# gpt/3 若 JSON 用欄位數字 ID，在設計模式查 ID 後設定（可留空則只用 book_id 等欄位名）
# RAGIC_CONTENT_FIELD_BOOK_ID=
# RAGIC_CONTENT_FIELD_BOOK_NAME=
# RAGIC_CONTENT_FIELD_DAY=
# RAGIC_CONTENT_FIELD_TITLE=
# RAGIC_CONTENT_FIELD_CONTENT=
# 若 Ragic 要求 API Key 用 query 傳送，設為 true（例：?APIKey=xxx）
RAGIC_API_KEY_IN_QUERY=
# Basic 認證：未設定或 true＝「Authorization: Basic 」+ 金鑰字面（與 Cloud Run deploy 一致）；僅在需要時設為 false 才用 Base64(apiKey:)
# RAGIC_BASIC_RAW=
# Wix 訂閱表（gpt/9）欄位 ID
# RAGIC_WIX_FIELD_NAME=1012061
# RAGIC_WIX_FIELD_EMAIL=1011774
# RAGIC_WIX_FIELD_MOBILE=1012062
# RAGIC_WIX_FIELD_COURSE_NAME=1011777
# RAGIC_WIX_FIELD_PRICE_AMOUNT=1011779
# RAGIC_WIX_FIELD_START_DATE=1011780
# RAGIC_WIX_FIELD_END_DATE=1011783
# RAGIC_WIX_FIELD_ORDER_NUMBE=1011778
# RAGIC_WIX_FIELD_TICKET_NUMBER=1012060

# 閱讀紀錄表（gpt/7）欄位 ID，每次閱讀寫入一筆。姓名 1011771、教會 1011772。
RAGIC_READING_RECORD_FIELD_USER_EMAIL=1011761
RAGIC_READING_RECORD_FIELD_BOOK_ID=1011762
RAGIC_READING_RECORD_FIELD_BOOK_NAME=1011763
RAGIC_READING_RECORD_FIELD_READING_DAY=1011764
RAGIC_READING_RECORD_FIELD_READ_TIME=1011765
RAGIC_READING_RECORD_FIELD_USER_NAME=1011771
RAGIC_READING_RECORD_FIELD_CHURCH=1011772

# 本地開發時可不設，Cloud Run 會設 PORT
PORT=8080

# Qdrant（整本手冊 QA 向量庫；Cloud 範例：https://xxxx.cloud.qdrant.io:6333）
QDRANT_URL=http://localhost:6333
# Qdrant Cloud 或需 API Key 的節點才填
QDRANT_API_KEY=
# 選填，預設 prayer_chunks
# QDRANT_COLLECTION=prayer_chunks

# 選填：與 Cloud Run 相同時，可 POST /internal/sync-ragic-to-qdrant（Header: Authorization: Bearer <此值>）
# SYNC_QDRANT_SECRET=

# OpenAI（embedding + chat，整本手冊 QA）
OPENAI_API_KEY=
